{
	"name": "Better Video Player",
	"description": "Adds features to the browser's video player",
	"version": "0.0.23",
	"version_name": "0.0.23",
	"manifest_version": 3,
	"background": {
		"service_worker": "background.js"
	},
	"action": {
		"default_popup": "options.html"
	},
	"permissions": [
		"storage"
	],
	"icons": {
		"16": "icon16.png",
		"32": "icon32.png",
		"48": "icon48.png",
		"128": "icon128.png"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"run_at": "document_idle"
		}
	]
}